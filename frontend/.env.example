# ── Backend API ───────────────────────────────────────────────────────────────
# Local development
API_BASE_URL=http://localhost:8080
# Railway production
# API_BASE_URL=https://whatyourhansome.railway.app

# ── Firebase Configuration ────────────────────────────────────────────────────
# Obtain these from the Firebase console → Project settings → Your apps → Web app
# These are used by flutter_dotenv at runtime (flutter build web reads .env via
# flutter_dotenv; for production, inject via Railway environment variables).
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
FACEBOOK_APP_ID=your_facebook_app_id
